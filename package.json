{
  "name": "piglog",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@11.12.1",
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=11.0.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "node scripts/dev-start.mjs",
    "dev:stop": "node scripts/dev-stop.mjs",
    "dev:web": "npm --workspace @piglog/web run dev",
    "dev:api": "npm --workspace @piglog/api run dev",
    "dev:worker": "npm --workspace @piglog/api run dev:worker",
    "dev:infra": "docker compose -f ops/docker/compose.dev.yml --env-file .env.dev up -d",
    "dev:infra:down": "docker compose -f ops/docker/compose.dev.yml --env-file .env.dev down",
    "db:generate": "npm --workspace @piglog/db run generate",
    "db:migrate": "npx tsx packages/db/src/migrate.ts",
    "db:studio": "npm --workspace @piglog/db run studio",
    "build:api": "npm --workspace @piglog/api run build",
    "build:web": "npm --workspace @piglog/web run build",
    "build:all": "npm run build:api && npm run build:web",
    "prod:build": "docker compose -f compose.prod.yml build",
    "prod:up": "docker compose -f compose.prod.yml --env-file .env.prod up -d",
    "prod:down": "docker compose -f compose.prod.yml down",
    "test:e2e": "npx playwright test",
    "test:e2e:ui": "npx playwright test --ui",
    "test:e2e:headed": "npx playwright test --headed"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "concurrently": "^9.2.1",
    "typescript": "6.0.3"
  },
  "dependencies": {
    "zod": "4.3.6"
  }
}
