# ============================================
# Piglog Production Environment
# ============================================

# Database
DB_USER=piglog
DB_PASSWORD=change_me_to_a_strong_password
DB_NAME=piglog_prod

# Redis
REDIS_PASSWORD=change_me_to_a_strong_password

# Application URLs
# APP_URL = the domain users visit (e.g. https://piglog.dev)
# API_URL = the API domain (e.g. https://api.piglog.dev)
# BETTER_AUTH_URL = must match API_URL for cookie auth to work
# VITE_API_URL = injected into the frontend build; must be the public API URL
APP_URL=https://piglog.dev
API_URL=https://api.piglog.dev
BETTER_AUTH_URL=https://api.piglog.dev
VITE_API_URL=https://api.piglog.dev

# Auth
# Generate a strong secret: openssl rand -base64 32
BETTER_AUTH_SECRET=change_me_to_a_strong_secret

# Optional social login
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
